# Standalone unstructured pipeline configuration

# MongoDB
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=healthai
MONGODB_COLLECTION=unstructured_documents

# Embedding provider: zhipu or openai
EMBEDDING_PROVIDER=zhipu

# Zhipu embeddings
ZHIPUAI_API_KEY=your_zhipu_api_key
ZHIPU_EMBEDDING_MODEL=embedding-3

# OpenAI embeddings
OPENAI_API_KEY=your_openai_api_key
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Chroma
CHROMA_PERSIST_DIR=./chroma_db_unstructured
CHROMA_COLLECTION_NAME=unstructured_healthcare
CHROMA_BATCH_SIZE=100

# Chunking
CHUNK_SIZE=1000
CHUNK_OVERLAP=150

# Input / output
UNSTRUCTURED_DOCS_JSONL=./Dataset/02_Unstructured/unstructured_documents.jsonl
UNSTRUCTURED_CHUNKS_JSONL=./Dataset/02_Unstructured/unstructured_chunks.jsonl
